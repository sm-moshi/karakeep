# Public URL used by NextAuth and generated links.
NEXTAUTH_URL=https://karakeep.example.com

# Replace with a published Postgres-only image tag.
KARAKEEP_IMAGE=ghcr.io/sm-moshi/karakeep
KARAKEEP_VERSION=postgres

# Karakeep stores application data and queue state in CNPG/Postgres.
DB_DRIVER=postgres

# Optional features.
MEILI_ADDR=http://meilisearch:7700
BROWSER_WEB_URL=http://chrome:9222
DATA_DIR=/data
